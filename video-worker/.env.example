# Ressy video worker-manager — config.
# This service holds NO tokens of its own: the Ressy bot registers worker
# tokens at runtime via the control API. Tokens are USER tokens (selfbots).
# ⚠️ Selfbots violate Discord ToS — use throwaway accounts only.

# Control API (bot-facing). The bot must send: Authorization: Bearer <secret>
MANAGER_PORT=8081
MANAGER_SECRET=change_me_shared_with_bot

# Player page server (Firefox-facing, bound to 127.0.0.1 inside the container).
HTTP_PORT=8080

# Concurrent workers (each needs an Xvfb display + pulse sink + Firefox + ffmpeg).
# Leave EMPTY to auto-size from host RAM: floor((totalRAM - reserve)/perWorker),
# hard-capped at 24. Set a number to force it.
MAX_WORKERS=
VIDEO_RAM_PER_WORKER_MB=1500
VIDEO_RAM_RESERVE_MB=3000
VIDEO_MAX_WORKERS_CAP=24

# --- default quality (overridable at runtime via PUT /quality) ---
WIDTH=1280
HEIGHT=720
FPS=30
BITRATE_KBPS=3000
BITRATE_MAX_KBPS=4500

FIREFOX_BIN=firefox-esr

# --- gateway de usuario (selfbot) ---
# discord.js-selfbot-v13 está deprecada y manda un IDENTIFY viejo que Discord
# rechaza (close 4013 "Invalid intent"). Estos overrides arreglan el handshake.
# Si sigue fallando, prueba otros capabilities (p.ej. 8189, 30717, 161789) o
# un client_build_number reciente.
DISCORD_WS_CAPABILITIES=16381
# DISCORD_WS_BUILD_NUMBER=
