# Ressy video worker-manager — config.
# This service holds NO tokens of its own: the Ressy bot registers worker
# tokens at runtime via the control API. Tokens are USER tokens (selfbots).
# ⚠️ Selfbots violate Discord ToS — use throwaway accounts only.

# Control API (bot-facing). The bot must send: Authorization: Bearer <secret>
MANAGER_PORT=8081
MANAGER_SECRET=change_me_shared_with_bot

# Concurrent workers (cada uno = 1 proceso ffmpeg de transcode + cliente selfbot).
# Leave EMPTY to auto-size from host RAM: floor((totalRAM - reserve)/perWorker),
# hard-capped at 24. Set a number to force it. OJO: el transcode 1080p es
# CPU-bound; en máquinas con mucha RAM y pocos núcleos conviene fijar este valor.
MAX_WORKERS=
VIDEO_RAM_PER_WORKER_MB=800
VIDEO_RAM_RESERVE_MB=2000
VIDEO_MAX_WORKERS_CAP=24

# --- default quality (overridable at runtime via PUT /quality) ---
WIDTH=1280
HEIGHT=720
FPS=30
BITRATE_KBPS=3000
BITRATE_MAX_KBPS=4500

# --- splash de carga ---
# Animación branded (ffmpeg) que se transmite ANTES del video, en el mismo
# stream (sin corte). Cubre el warmup de yt-dlp/ffmpeg/handshake. 0 = desactivar.
VIDEO_SPLASH_SECONDS=4
# VIDEO_SPLASH_TITLE=RessyTube
# VIDEO_SPLASH_TEXT=cargando...
# VIDEO_SPLASH_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

# --- yt-dlp ---
# Binario (default yt-dlp en PATH). YTDLP_FORMAT: selector de formato (default
# prioriza H264+AAC hasta 1080p). YTDLP_COOKIES: ruta a cookies.txt para videos
# con login / age-restricted (opcional).
# YTDLP_BIN=yt-dlp
# YTDLP_FORMAT=bestvideo[height<=?1080]+bestaudio/best
# YTDLP_COOKIES=/app/cookies.txt

# --- gateway de usuario (selfbot) ---
# discord.js-selfbot-v13 está deprecada y manda un IDENTIFY viejo que Discord
# rechaza (close 4013 "Invalid intent"). Estos overrides arreglan el handshake.
# Si sigue fallando, prueba otros capabilities (p.ej. 8189, 30717, 161789) o
# un client_build_number reciente.
DISCORD_WS_CAPABILITIES=16381
# DISCORD_WS_BUILD_NUMBER=
