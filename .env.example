DISCORD_TOKEN=your_token_here
DATABASE_PATH=data/bot.db
HOST=0.0.0.0
PORT=8000

# ── Code Runner (Piston sandbox) ──────────────────────────────
# Piston corre como servicio en el mismo compose (red Docker interna).
# Default: http://piston:2000/api/v2 (self-hosted). No requiere setup en el host.
# Si Piston está en otro servidor, descomenta:
# PISTON_URL=http://otro-servidor:2000

# ── Videos (RessyTube — worker-manager de selfbots) ───────────
# El servicio video-worker corre en el mismo compose (red interna).
# Default URL: http://video-worker:8081
# VIDEO_MANAGER_URL=http://video-worker:8081
# Secreto compartido (bearer) entre bot y worker-manager. DEFÍNELO en ambos.
VIDEO_MANAGER_SECRET=cambia_esto_por_un_secreto_largo
# Cap de workers simultáneos (cada uno = display + audio + Firefox + ffmpeg).
# Déjalo VACÍO para auto-calcular por RAM del host: floor((RAM - reserva)/perWorker),
# tope 24. Pon un número para forzarlo.
VIDEO_MAX_WORKERS=
# Presupuesto de RAM del auto-cálculo (host de 32GB → ~19 workers con defaults).
VIDEO_RAM_PER_WORKER_MB=1500
VIDEO_RAM_RESERVE_MB=3000
# Calidad por defecto (overridable desde el dashboard).
# VIDEO_WIDTH=1280
# VIDEO_HEIGHT=720
# VIDEO_FPS=30
# VIDEO_BITRATE_KBPS=3000
# VIDEO_BITRATE_MAX_KBPS=4500
